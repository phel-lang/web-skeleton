(ns web-skeleton.app
  (:require web-skeleton.router :as router)
  (:require phel.http :as h))

;; Entry point: build the request from PHP globals, run it through the app
;; handler, emit the response. The route table and wiring live in
;; web-skeleton.router; everything here is the IO edge.
(when-not *build-mode*
  (h/emit-response (router/app (h/request-from-globals))))
